# Novel2Script 环境变量模板
# 复制此文件为 .env 或 .env.local

# API 后端地址
VITE_API_BASE_URL=http://localhost:8000/api

# 是否使用模拟模式
VITE_USE_MOCK=true

# ========== AI API 配置（可选） ==========
# 现在支持在界面上直接选择 AI 服务和配置 Key，无需编辑此文件！
# 支持的免费/低价 AI 服务：
#   - DeepSeek（国产，¥1/百万tokens，注册送500万tokens）
#   - 智谱 GLM（清华系，GLM-4-Flash 免费调用）
#   - 通义千问（阿里云，百万tokens免费额度）
#   - 硅基流动（模型聚合平台，新用户赠送额度）
#   - OpenAI（GPT-4o-mini）
#   - 自定义（兼容任何 OpenAI 接口格式的服务）
#
# 以下环境变量为可选的后备方案，界面未配置时生效：

# AI API Key
# VITE_AI_API_KEY=sk-your-api-key-here

# AI API 地址（默认 OpenAI，可替换为其他兼容服务）
# VITE_AI_API_URL=https://api.openai.com/v1/chat/completions

# AI 模型名称
# VITE_AI_MODEL=gpt-4o-mini
